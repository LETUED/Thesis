# THESIS 백엔드 환경변수 예시
# 사용법: 이 파일을 .env 로 복사한 뒤 값을 채운다.
#   cp .env.example .env   (PowerShell: Copy-Item .env.example .env)
#
# 모든 변수는 THESIS_ prefix 를 쓴다 (pydantic-settings, env_prefix="THESIS_").
# 중첩 설정은 이중 언더스코어(__)로 접근한다.
#   예) THESIS_REGIME__MIN_COVERAGE=0.6
#
# 아래 THESIS_* 는 전부 선택값이다. 미지정 시 app/config.py 의 기본값이 적용된다.
# 단, Supabase 인증 변수는 prefix 없는 bare 이름이며(아래 참고), 실서비스에선 필수다.

# ── Supabase 인증 (prefix 없음 — bare 이름. 인증/Pro 게이팅에 사용) ──
# 미설정 시 토큰 검증/티어 조회가 비활성화되어 모든 요청이 익명(free)로 처리된다.
# SECRET_KEY 는 service_role 키(RLS 우회) — 서버 전용, 프론트에 절대 노출 금지.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# SUPABASE_SECRET_KEY=sb_secret_...

# ── CORS (prefix 없음 — bare 이름. main.py 가 읽도록 별도 정리 예정) ──
# CORS_ORIGINS=["http://localhost:3000"]

# ── DART(전자공시) 한국 기업 재무 (prefix 없음 — bare 이름) ──
# 무료 발급: https://opendart.fss.or.kr → 가입 → '인증키 신청/관리' → 이메일 인증 → 40자리 키.
# 미설정 시 한국 종목은 yfinance/mock 폴백(가짜 숫자 금지). corpCode 매핑은 .cache 에 1회 캐시.
# DART_API_KEY=발급받은_40자리_키

# ── 앱 ──────────────────────────────────────────────
# THESIS_APP_NAME=THESIS Backend
# THESIS_VERSION=0.1.0

# ── 캐시 / 수집기 ───────────────────────────────────
# in-memory TTL 캐시 (초). 기본 1800 = 30분.
# THESIS_CACHE_TTL_SECONDS=1800
# yfinance 호출 타임아웃 (초).
# THESIS_COLLECTOR_TIMEOUT_SEC=10.0

# ── CORS (프론트엔드 오리진) ────────────────────────
# JSON 배열 형식으로 지정.
# THESIS_CORS_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]

# ── 매크로 임계값 (개별 노출용 — 엔진은 regime/allocation config 사용) ──
# THESIS_VIX_RISK=25.0
# THESIS_VIX_CALM=15.0
# THESIS_DXY_WATCH=105.0
# THESIS_USDKRW_CAUTION=1400.0
# THESIS_USDKRW_RISK=1500.0
# THESIS_FOREIGN_SELL_STREAK=10

# ── 자산배분 제약 ───────────────────────────────────
# THESIS_MAX_SINGLE_POSITION_PCT=15.0
# THESIS_MIN_CASH_PCT=20.0

# ── 기업 분석 임계값 ────────────────────────────────
# THESIS_PEG_MAX=1.0
# THESIS_ROE_MIN=15.0
# THESIS_OP_MARGIN_MIN=20.0

# ── 중첩 엔진 설정 오버라이드 예시 ──────────────────
# regime 컷오프 / 커버리지
# THESIS_REGIME__CUTOFF_RISK_ON=25.0
# THESIS_REGIME__CUTOFF_RISK_OFF=-25.0
# THESIS_REGIME__MIN_COVERAGE=0.5
# allocation 제약
# THESIS_ALLOCATION__MIN_CASH_PCT=20.0
# THESIS_ALLOCATION__MAX_SINGLE_POSITION_PCT=15.0
