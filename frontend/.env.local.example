# THESIS 프론트엔드 환경변수 예시
# 실제 값은 .env.local 에 넣으세요(커밋 금지). NEXT_PUBLIC_ 접두사만 브라우저에 노출됩니다.
# 시크릿(서비스 롤 키 등)은 절대 NEXT_PUBLIC_ 으로 넣지 마세요.

# 백엔드 FastAPI 베이스 URL (로컬 개발 기본값)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Supabase 프로젝트 URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase publishable(anon) 키 — 공개 가능한 키만 사용
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key
